{
  "title": "Access Logs (Gateway)",
  "uid": "tenzoshare-access-logs",
  "tags": [
    "tenzoshare",
    "logs",
    "traefik"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Request Rate by Status Class",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(rate({service=\"tenzoshare-gateway\"} | json | DownstreamStatus >= 500 [5m]))",
          "legendFormat": "5xx",
          "refId": "A"
        },
        {
          "expr": "sum(rate({service=\"tenzoshare-gateway\"} | json | DownstreamStatus >= 400 | DownstreamStatus < 500 [5m]))",
          "legendFormat": "4xx",
          "refId": "B"
        },
        {
          "expr": "sum(rate({service=\"tenzoshare-gateway\"} | json | DownstreamStatus >= 300 | DownstreamStatus < 400 [5m]))",
          "legendFormat": "3xx",
          "refId": "C"
        },
        {
          "expr": "sum(rate({service=\"tenzoshare-gateway\"} | json | DownstreamStatus >= 200 | DownstreamStatus < 300 [5m]))",
          "legendFormat": "2xx",
          "refId": "D"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Request Rate by HTTP Method",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum by (RequestMethod) (rate({service=\"tenzoshare-gateway\"} | json [5m]))",
          "legendFormat": "{{RequestMethod}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Slow Requests (>500ms)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum (rate({service=\"tenzoshare-gateway\"} | json | Duration > 500000000 [5m]))",
          "legendFormat": "slow requests/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "logs",
      "title": "Gateway Access Log Stream",
      "gridPos": {
        "h": 20,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{service=\"tenzoshare-gateway\"} | json",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ]
}