{
  "title": "Transfer Activity",
  "uid": "tenzoshare-transfer-activity",
  "tags": [
    "tenzoshare",
    "transfers",
    "logs"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "Transfers Created",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"tenzoshare-gateway\"} | json | RequestPath=\"/api/v1/transfers\" | RequestMethod=\"POST\" | DownstreamStatus = 201 [$__interval]))",
          "legendFormat": "transfers created",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "File Downloads",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"tenzoshare-gateway\"} | json | RequestPath=~\"/api/v1/t/.+/files/.+/download\" [$__interval]))",
          "legendFormat": "downloads",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Auth Events (login/logout/fail)",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"tenzoshare-gateway\"} | json | RequestPath=\"/api/v1/auth/login\" | RequestMethod=\"POST\" | DownstreamStatus = 200 [$__interval]))",
          "legendFormat": "login success",
          "refId": "A"
        },
        {
          "expr": "sum(count_over_time({service=\"tenzoshare-gateway\"} | json | RequestPath=\"/api/v1/auth/login\" | RequestMethod=\"POST\" | DownstreamStatus = 401 [$__interval]))",
          "legendFormat": "login failed",
          "refId": "B"
        },
        {
          "expr": "sum(count_over_time({service=\"tenzoshare-gateway\"} | json | RequestPath=\"/api/v1/auth/logout\" | RequestMethod=\"POST\" [$__interval]))",
          "legendFormat": "logout",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Upload Events",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service=\"tenzoshare-gateway\"} | json | RequestPath=~\"/api/v1/(uploads|files).*\" | RequestMethod=\"POST\" | DownstreamStatus < 500 [$__interval]))",
          "legendFormat": "uploads",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate (all services)",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "sum by (ServiceName) (count_over_time({service=\"tenzoshare-gateway\"} | json | DownstreamStatus >= 500 [$__interval]))",
          "legendFormat": "{{ServiceName}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          }
        }
      }
    },
    {
      "type": "logs",
      "title": "Recent Transfer & Auth Events",
      "gridPos": {
        "h": 16,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{service=\"tenzoshare-gateway\"} | json | RequestPath=~\"/api/v1/(transfers|auth|uploads|t)/.*\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ]
}