{
  "title": "Transfer Activity",
  "uid": "tenzoshare-transfer-activity",
  "tags": ["tenzoshare", "transfers", "logs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "type": "timeseries",
      "title": "Transfers Created",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum (rate({service=\"tenzoshare-transfer\"} | json | msg=\"transfer created\" [5m]))",
          "legendFormat": "created/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "File Downloads",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum (rate({service=\"tenzoshare-transfer\"} | json | msg=~\"download url generated|file download\" [5m]))",
          "legendFormat": "downloads/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Auth Events (login/logout/fail)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum by (msg) (rate({service=\"tenzoshare-auth\"} | json | msg=~\"login success|login failed|logout\" [5m]))",
          "legendFormat": "{{msg}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Upload Events",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum (rate({service=\"tenzoshare-upload\"} | json | level!=\"error\" [5m]))",
          "legendFormat": "upload events/s",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error Rate (all services)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "sum by (service) (rate({service=~\"tenzoshare-.+\"} | json | level=\"error\" [5m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "red", "mode": "fixed" } } }
    },
    {
      "type": "logs",
      "title": "Recent Transfer & Auth Events",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{service=~\"tenzoshare-transfer|tenzoshare-auth|tenzoshare-upload\"} | json",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "__inputs": [{ "name": "DS_LOKI", "label": "Loki", "type": "datasource", "pluginId": "loki" }],
  "__requires": [{ "type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0" }]
}
