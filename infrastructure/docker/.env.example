# =============================================================================
# TenzoShare — Local Development Environment
# Copy to .env and fill in your values. Never commit .env to version control.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
# Base URL used for absolute link generation (email links, OIDC redirect URIs).
BASE_URL=http://localhost
# DEV_MODE=true disables HSTS, allows Secure:false cookies, relaxes CORS.
DEV_MODE=true
LOG_LEVEL=debug

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=tenzoshare-db
POSTGRES_PORT=5432
POSTGRES_DB=tenzoshare
POSTGRES_USER=tenzoshare
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_SSLMODE=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=tenzoshare-redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_local_only
REDIS_DB=0

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_local_only
S3_ENDPOINT=http://tenzoshare-minio:9000
S3_BUCKET=tenzoshare
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=changeme_local_only
# Set to false for local MinIO (HTTP), true for real AWS S3 (HTTPS)
S3_USE_SSL=false

# ── NATS ──────────────────────────────────────────────────────────────────────
NATS_URL=nats://tenzoshare-nats:4222

# ── JWT / Auth (RS256 asymmetric keys) ────────────────────────────────────────
# Generate with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt_private.pem
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# Then escape newlines: cat jwt_private.pem | python3 -c "import sys; print(sys.stdin.read().replace('\n', '\\\\n').strip())"
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ── Bootstrap admin account (auth service startup) ───────────────────────────
# Used to create/promote the initial admin user every startup in local dev.
BOOTSTRAP_ADMIN_EMAIL=admin@tenzoshare.local
BOOTSTRAP_ADMIN_PASSWORD=changeme_admin_local_only

# ── Argon2id Password Pepper ──────────────────────────────────────────────────
# Separate secret mixed into all password hashes. Generate with: openssl rand -hex 32
# WARNING: changing this invalidates all existing password hashes.
PASSWORD_PEPPER=changeme_use_openssl_rand_hex_32_in_production

# ── AES-256-GCM File Encryption Key ─────────────────────────────────────────
# 64-char hex string (32 bytes). Generate with: openssl rand -hex 32
# WARNING: changing this makes all existing encrypted files unreadable.
STORAGE_ENCRYPTION_KEY=changeme_use_openssl_rand_hex_32_in_production

# ── Service Ports ─────────────────────────────────────────────────────────────
AUTH_PORT=8081
TRANSFER_PORT=8082
STORAGE_PORT=8083
UPLOAD_PORT=8084
NOTIFICATION_PORT=8085
AUDIT_PORT=8086
ADMIN_PORT=8087

# ── Observability (optional, used with docker-compose.observability.yml) ──────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_local_only
